 <style>
  /* Airbnb-Style Flash Notifications */
  .flash-container {
    position: fixed;
    top: 100px;
    right: 24px;
    z-index: 9999;
    max-width: 380px;
    width: calc(100% - 48px);
  }
  
  .flash-alert {
    border-radius: 14px;
    padding: 1rem 1.25rem;
    box-shadow: rgba(0, 0, 0, 0.02) 0 0 0 1px, rgba(0, 0, 0, 0.04) 0 2px 6px 0, rgba(0, 0, 0, 0.1) 0 4px 8px 0;
    border: 1px solid #dddddd;
    background: #ffffff;
    animation: slideInRight 0.3s ease, fadeOut 0.3s ease 4.7s forwards;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 500;
    font-size: 0.875rem;
    color: #222222;
  }
  
  .flash-alert i {
    font-size: 1.125rem;
    flex-shrink: 0;
  }
  
  .flash-success {
    background: #ffffff;
    border-color: #dddddd;
  }
  
  .flash-success i {
    color: #008A05;
  }
  
  .flash-error {
    background: #ffffff;
    border-color: #dddddd;
  }
  
  .flash-error i {
    color: #c13515;
  }
  
  .flash-alert .btn-close {
    opacity: 0.5;
    font-size: 0.75rem;
  }
  
  .flash-alert .btn-close:hover {
    opacity: 1;
  }
  
  @keyframes slideInRight {
    from {
      transform: translateX(400px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }
  
  @keyframes fadeOut {
    to {
      opacity: 0;
      transform: translateX(400px);
    }
  }
  
  @media (max-width: 768px) {
    .flash-container {
      top: 90px;
      right: 16px;
      left: 16px;
      max-width: 100%;
      width: auto;
    }
    
    .flash-alert {
      padding: 0.875rem 1rem;
      font-size: 0.8125rem;
    }
    
    .flash-alert i {
      font-size: 1rem;
    }
  }
  
  @media (max-width: 576px) {
    .flash-container {
      top: 90px;
    }
  }
</style>

<div class="flash-container">
  <% if (Sucess && Sucess.length) { %>
    <div class="alert flash-alert flash-success alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-circle-check"></i>
      <span><%= Sucess %></span>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <% if (error && error.length) { %>
    <div class="alert flash-alert flash-error alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span><%= error %></span>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
</div>

<script>
  // Auto-dismiss flash messages after 5 seconds
  setTimeout(() => {
    const flashAlerts = document.querySelectorAll('.flash-alert');
    flashAlerts.forEach(alert => {
      const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
      bsAlert.close();
    });
  }, 5000);
</script>