<style>
  /* Airbnb-Style Hero - Clean & Minimal */
  .premium-hero {
    background: #ffffff;
    color: #222222;
    padding: 4rem 2rem 3rem;
    margin: 0 0 3rem 0;
    text-align: center;
  }

  .hero-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.18;
    letter-spacing: -0.44px;
    color: #222222;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: #6a6a6a;
    margin-bottom: 2rem;
    font-weight: 500;
    line-height: 1.43;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #ff385c;
    color: white;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hero-cta:hover {
    background: #e00b41;
    color: white;
    transform: scale(0.96);
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .premium-hero {
      padding: 3rem 1.5rem 2rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-cta {
      padding: 0.75rem 1.25rem;
      font-size: 0.9375rem;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>

<div class="premium-hero">
  <div class="hero-content">
    <h1 class="hero-title">Find your next stay</h1>
    <p class="hero-subtitle">
      Discover entire homes and rooms perfect for any trip
    </p>
    
    <% if (!CurrUser) { %>
      <a href="/login" class="hero-cta">
        Get started
      </a>
    <% } else { %>
      <a href="/listings/new" class="hero-cta">
        <i class="fa-solid fa-plus"></i>
        <span>List your property</span>
      </a>
    <% } %>
  </div>
</div>
