<style>
  /* Airbnb-Style Footer */
  .premium-footer {
    background: #f7f7f7;
    color: #222222;
    border-top: 1px solid #dddddd;
    padding: 3rem 0 1.5rem;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h5 {
    font-size: 0.75rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    color: #222222;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .footer-bottom {
    border-top: 1px solid #dddddd;
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom-left {
    color: #222222;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .footer-bottom-right {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-bottom-right a {
    color: #222222;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .footer-bottom-right a:hover {
    text-decoration: underline;
  }

  .language-currency {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .lang-btn, .currency-btn {
    background: transparent;
    border: 1px solid #dddddd;
    border-radius: 8px;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #222222;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-btn:hover, .currency-btn:hover {
    border-color: #222222;
  }

  @media (max-width: 768px) {
    .premium-footer {
      padding: 2rem 0 1rem;
    }

    .footer-content {
      padding: 0 1rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }

    .footer-bottom-right {
      justify-content: center;
    }

    .language-currency {
      justify-content: center;
    }
  }
</style>

<footer class="premium-footer">
  <div class="footer-content">
    <div class="footer-grid">
      <!-- Support -->
      <div class="footer-section">
        <h5>Support</h5>
        <ul class="footer-links">
          <li><a href="/help">Help Center</a></li>
          <li><a href="/safety">Safety</a></li>
          <li><a href="/cancellation">Cancellation</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Hosting -->
      <div class="footer-section">
        <h5>Hosting</h5>
        <ul class="footer-links">
          <li><a href="/listings/new">List Your Property</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/careers">Careers</a></li>
          <li><a href="/press">Press</a></li>
        </ul>
      </div>

      <!-- WandurLust -->
      <div class="footer-section">
        <h5>WandurLust</h5>
        <ul class="footer-links">
          <li><a href="/terms">Terms of Service</a></li>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/cookies">Cookie Policy</a></li>
          <li><a href="/sitemap">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-left">
        © <%= new Date().getFullYear() %> WandurLust, Inc. All rights reserved.
      </div>
      
      <div class="language-currency">
        <button class="lang-btn">
          <i class="fa-solid fa-globe"></i>
          <span>English (US)</span>
        </button>
        <button class="currency-btn">
          <span>$ USD</span>
        </button>
      </div>
    </div>
  </div>
</footer>
