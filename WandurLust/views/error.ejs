<%layout("/layouts/boilerplate")%>

<style>
    /* Airbnb-Style Error Page */
    .error-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
    
    .error-card {
        background: #ffffff;
        border: 1px solid #dddddd;
        border-radius: 20px;
        overflow: hidden;
        max-width: 600px;
        width: 100%;
        box-shadow: rgba(0, 0, 0, 0.02) 0 0 0 1px, rgba(0, 0, 0, 0.04) 0 2px 6px 0, rgba(0, 0, 0, 0.1) 0 4px 8px 0;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .error-header {
        background: #ffffff;
        color: #222222;
        padding: 3rem 2rem 2rem;
        text-align: center;
        border-bottom: 1px solid #dddddd;
    }
    
    .error-icon-wrapper {
        width: 100px;
        height: 100px;
        background: #f7f7f7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }
    
    .error-icon {
        font-size: 3rem;
        color: #222222;
    }
    
    .error-code {
        font-size: 4rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -1.5px;
        color: #222222;
    }

    .error-title {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 1rem 0 0 0;
        letter-spacing: -0.44px;
        color: #222222;
    }
    
    .error-body {
        padding: 2rem;
        text-align: center;
    }
    
    .error-message {
        font-size: 1rem;
        font-weight: 500;
        color: #6a6a6a;
        margin-bottom: 2rem;
        line-height: 1.43;
    }
    
    .error-suggestions {
        background: #f7f7f7;
        border: 1px solid #dddddd;
        border-radius: 14px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        text-align: left;
    }
    
    .suggestions-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 1rem;
        letter-spacing: 0;
    }
    
    .suggestions-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        color: #6a6a6a;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .suggestion-item i {
        width: 20px;
        height: 20px;
        background: #222222;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.625rem;
        flex-shrink: 0;
    }
    
    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn-error {
        padding: 0.875rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: 0;
    }
    
    .btn-primary-error {
        background: #ff385c;
        color: white;
        border: none;
    }
    
    .btn-primary-error:hover {
        background: #e00b41;
        transform: scale(0.96);
        color: white;
    }
    
    .btn-secondary-error {
        background: transparent;
        color: #222222;
        border: 1px solid #dddddd;
    }
    
    .btn-secondary-error:hover {
        background: #f7f7f7;
        border-color: #222222;
        color: #222222;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .error-header {
            padding: 2.5rem 1.5rem 2rem;
        }

        .error-icon-wrapper {
            width: 80px;
            height: 80px;
        }
        
        .error-icon {
            font-size: 2.5rem;
        }

        .error-code {
            font-size: 3rem;
        }
        
        .error-title {
            font-size: 1.25rem;
        }
        
        .error-body {
            padding: 2rem 1.5rem;
        }
        
        .error-message {
            font-size: 0.9375rem;
        }
        
        .error-suggestions {
            padding: 1.25rem;
        }
        
        .error-actions {
            flex-direction: column;
        }
        
        .btn-error {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="error-container">
    <div class="error-card">
        <div class="error-header">
            <div class="error-icon-wrapper">
                <i class="fa-solid fa-triangle-exclamation error-icon"></i>
            </div>
            <h1 class="error-code">404</h1>
            <h2 class="error-title">Page Not Found</h2>
        </div>
        
        <div class="error-body">
            <div class="error-message">
                <%= message || "We can't seem to find the page you're looking for." %>
            </div>
            
            <div class="error-suggestions">
                <h3 class="suggestions-title">Here are some helpful links:</h3>
                <ul class="suggestions-list">
                    <li class="suggestion-item">
                        <i class="fa-solid fa-check"></i>
                        <span>Check the URL for typos</span>
                    </li>
                    <li class="suggestion-item">
                        <i class="fa-solid fa-check"></i>
                        <span>Go back to the previous page</span>
                    </li>
                    <li class="suggestion-item">
                        <i class="fa-solid fa-check"></i>
                        <span>Visit our homepage</span>
                    </li>
                </ul>
            </div>
            
            <div class="error-actions">
                <a href="javascript:history.back()" class="btn-error btn-secondary-error">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Go Back</span>
                </a>
                <a href="/listings" class="btn-error btn-primary-error">
                    <i class="fa-solid fa-house"></i>
                    <span>Home</span>
                </a>
            </div>
        </div>
    </div>
</div>
