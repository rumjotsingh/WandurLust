<% layout("/layouts/boilerplate") %>

<style>
  /* Premium My Trips Page - Airbnb Style */
  .trips-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
  }

  .trips-header {
    margin-bottom: 2.5rem;
    animation: fadeInDown 0.6s ease;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .trips-title {
    font-size: 2rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 0.5rem;
    letter-spacing: -0.5px;
  }

  .trips-subtitle {
    font-size: 1rem;
    color: #6a6a6a;
    font-weight: 400;
  }

  /* Tabs */
  .trips-tabs {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid #dddddd;
    margin-bottom: 2rem;
  }

  .tab-item {
    padding: 1rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: #6a6a6a;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .tab-item:hover {
    color: #222222;
  }

  .tab-item.active {
    color: #222222;
    border-bottom-color: #222222;
  }

  /* Trip Cards Grid */
  .trips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    animation: fadeInUp 0.6s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Trip Card */
  .trip-card {
    background: #ffffff;
    border: 1px solid #dddddd;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .trip-card:hover {
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  .trip-image-wrapper {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .trip-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .trip-card:hover .trip-image {
    transform: scale(1.05);
  }

  .trip-status-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
  }

  .trip-status-badge.confirmed {
    background: rgba(46, 125, 50, 0.9);
    color: #ffffff;
  }

  .trip-status-badge.cancelled {
    background: rgba(198, 40, 40, 0.9);
    color: #ffffff;
  }

  .trip-status-badge.completed {
    background: rgba(21, 101, 192, 0.9);
    color: #ffffff;
  }

  .trip-content {
    padding: 1.25rem;
  }

  .trip-dates {
    font-size: 0.8125rem;
    color: #6a6a6a;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .trip-title {
    font-size: 1rem;
    font-weight: 600;
    color: #222222;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }

  .trip-location {
    font-size: 0.875rem;
    color: #6a6a6a;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .trip-details {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid #ebebeb;
    border-bottom: 1px solid #ebebeb;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
    color: #6a6a6a;
  }

  .trip-detail-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .trip-detail-item i {
    font-size: 0.75rem;
  }

  .trip-price {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .trip-price-amount {
    font-size: 1.125rem;
    font-weight: 700;
    color: #222222;
  }

  .trip-price-label {
    font-size: 0.8125rem;
    color: #6a6a6a;
  }

  .trip-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .btn-trip-action {
    flex: 1;
    padding: 0.625rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid #222222;
  }

  .btn-trip-primary {
    background: #222222;
    color: #ffffff;
  }

  .btn-trip-primary:hover {
    background: #000000;
    color: #ffffff;
  }

  .btn-trip-secondary {
    background: transparent;
    color: #222222;
  }

  .btn-trip-secondary:hover {
    background: #f7f7f7;
    color: #222222;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    animation: fadeIn 0.6s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .empty-icon {
    width: 120px;
    height: 120px;
    background: #f7f7f7;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .empty-icon i {
    font-size: 3rem;
    color: #b0b0b0;
  }

  .empty-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #222222;
    margin-bottom: 0.75rem;
  }

  .empty-text {
    font-size: 1rem;
    color: #6a6a6a;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .btn-explore {
    background: #222222;
    color: #ffffff;
    border: none;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .btn-explore:hover {
    background: #000000;
    color: #ffffff;
    transform: scale(0.98);
  }

  /* Quick Links */
  .quick-links {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 1rem 1.5rem;
    background: #f7f7f7;
    border-radius: 12px;
  }

  .quick-link {
    color: #222222;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .quick-link:hover {
    color: #000000;
    gap: 0.75rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .trips-container {
      padding: 2rem 1.5rem 3rem;
    }

    .trips-title {
      font-size: 1.75rem;
    }

    .trips-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .trips-tabs {
      gap: 1rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .tab-item {
      white-space: nowrap;
    }

    .quick-links {
      flex-direction: column;
      gap: 1rem;
      align-items: stretch;
    }

    .quick-link {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .trips-container {
      padding: 1.5rem 1rem 2rem;
    }

    .trips-title {
      font-size: 1.5rem;
    }

    .trip-actions {
      flex-direction: column;
    }
  }
</style>

<div class="trips-container">
  <!-- Header -->
  <div class="trips-header">
    <h1 class="trips-title">Trips</h1>
    <p class="trips-subtitle">Manage your bookings and explore new destinations</p>
  </div>

  <!-- Quick Links -->
  <div class="quick-links">
    <a href="/bookings/host" class="quick-link">
      <i class="fa-solid fa-home"></i>
      View bookings for my listings
    </a>
    <a href="/" class="quick-link">
      <i class="fa-solid fa-magnifying-glass"></i>
      Explore more stays
    </a>
  </div>

  <!-- Tabs -->
  <div class="trips-tabs">
    <div class="tab-item active">All trips (<%= bookings.length %>)</div>
  </div>

  <% if (bookings.length === 0) { %>
    <!-- Empty State -->
    <div class="empty-state">
      <div class="empty-icon">
        <i class="fa-solid fa-suitcase-rolling"></i>
      </div>
      <h2 class="empty-title">No trips yet</h2>
      <p class="empty-text">
        Time to dust off your bags and start planning your next adventure.<br>
        Discover amazing places to stay around the world.
      </p>
      <a href="/" class="btn-explore">
        <i class="fa-solid fa-compass"></i>
        Start exploring
      </a>
    </div>
  <% } else { %>
    <!-- Trips Grid -->
    <div class="trips-grid">
      <% bookings.forEach(booking => { %>
        <a href="/bookings/<%= booking._id %>" class="trip-card">
          <div class="trip-image-wrapper">
            <% if (booking.listing && booking.listing.image) { %>
              <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>" class="trip-image">
            <% } %>
            <span class="trip-status-badge <%= booking.status %>">
              <% if (booking.status === 'confirmed') { %>
                <i class="fa-solid fa-circle-check"></i> Confirmed
              <% } else if (booking.status === 'cancelled') { %>
                <i class="fa-solid fa-circle-xmark"></i> Cancelled
              <% } else { %>
                <%= booking.status %>
              <% } %>
            </span>
          </div>
          <div class="trip-content">
            <div class="trip-dates">
              <%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> - 
              <%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </div>
            <% if (booking.listing) { %>
              <h3 class="trip-title"><%= booking.listing.title %></h3>
              <p class="trip-location">
                <i class="fa-solid fa-location-dot"></i>
                <%= booking.listing.location %>, <%= booking.listing.country %>
              </p>
            <% } else { %>
              <h3 class="trip-title">Listing Unavailable</h3>
            <% } %>
            <div class="trip-details">
              <div class="trip-detail-item">
                <i class="fa-solid fa-moon"></i>
                <%= booking.numberOfNights %> <%= booking.numberOfNights === 1 ? 'night' : 'nights' %>
              </div>
              <div class="trip-detail-item">
                <i class="fa-solid fa-users"></i>
                <%= booking.guests %> <%= booking.guests === 1 ? 'guest' : 'guests' %>
              </div>
            </div>
            <div class="trip-price">
              <div>
                <div class="trip-price-amount">₹<%= booking.totalPrice.toLocaleString('en-IN') %></div>
                <div class="trip-price-label">Total price</div>
              </div>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>
