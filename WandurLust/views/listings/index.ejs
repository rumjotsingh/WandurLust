<% layout("/layouts/boilerplate") %>

<style>
    /* Premium Homepage Container */
    .homepage-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
    }

    /* Premium Category Filters - Horizontal Scroll */
    .categories-wrapper {
        position: sticky;
        top: 100px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 100;
        padding: 1.5rem 0;
        margin: 0 -2rem 2rem;
        padding-left: 2rem;
        padding-right: 2rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .categories-scroll {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 0.5rem;
    }

    .categories-scroll::-webkit-scrollbar {
        display: none;
    }

    .category-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 16px;
        text-decoration: none;
        color: rgba(0, 0, 0, 0.6);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
        min-width: fit-content;
        cursor: pointer;
    }

    .category-item:hover {
        background: rgba(0, 0, 0, 0.03);
        color: #000000;
        border-color: rgba(0, 0, 0, 0.08);
    }

    .category-item.active {
        background: #000000;
        color: white;
        border-color: #000000;
    }

    .category-item i {
        font-size: 1.5rem;
        transition: transform 0.3s ease;
    }

    .category-item:hover i {
        transform: scale(1.1);
    }

    .category-item.active i {
        transform: scale(1.05);
    }

    .category-name {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: -0.2px;
    }

    /* Premium Listings Grid - 3 Columns */
    .listings-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
        animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Premium Listing Card */
    .listing-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
    }

    .listing-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        border-color: rgba(0, 0, 0, 0.12);
    }

    .listing-image-wrapper {
        position: relative;
        width: 100%;
        height: 320px;
        overflow: hidden;
    }

    .listing-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .listing-card:hover .listing-image {
        transform: scale(1.05);
    }

    .placement-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(10px);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        z-index: 10;
    }

    .badge-luxury {
        background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
    }

    .badge-premium {
        background: linear-gradient(135deg, #2a2a2a 0%, #3a3a3a 100%);
    }

    .favorite-btn {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        z-index: 10;
    }

    .favorite-btn:hover {
        background: white;
        transform: scale(1.1);
    }

    .favorite-btn i {
        font-size: 1.1rem;
        color: #000000;
    }

    .listing-content {
        padding: 1.5rem;
    }

    .listing-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #000000;
        margin-bottom: 0.5rem;
        letter-spacing: -0.3px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .listing-location {
        color: rgba(0, 0, 0, 0.6);
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .listing-location i {
        font-size: 0.85rem;
    }

    .listing-price {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    .price-amount {
        font-size: 1.25rem;
        font-weight: 800;
        color: #000000;
        letter-spacing: -0.5px;
    }

    .price-period {
        font-size: 0.9rem;
        color: rgba(0, 0, 0, 0.6);
    }

    /* Pagination */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    .pagination-btn {
        background: transparent;
        color: #000000;
        border: 1px solid rgba(0, 0, 0, 0.15);
        padding: 0.75rem 1.25rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pagination-btn:hover {
        background: rgba(0, 0, 0, 0.05);
        border-color: #000000;
        color: #000000;
    }

    .pagination-btn.active {
        background: #000000;
        color: white;
        border-color: #000000;
    }

    .pagination-btn.prev,
    .pagination-btn.next {
        background: #000000;
        color: white;
        border-color: #000000;
    }

    .pagination-btn.prev:hover,
    .pagination-btn.next:hover {
        background: #1a1a1a;
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    }

    .pagination-dots {
        color: rgba(0, 0, 0, 0.4);
        padding: 0 0.5rem;
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .listings-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }
    }

    @media (max-width: 768px) {
        .homepage-container {
            padding: 0 1rem 3rem;
        }

        .categories-wrapper {
            margin: 0 -1rem 1.5rem;
            padding-left: 1rem;
            padding-right: 1rem;
            top: 80px;
        }

        .listings-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .listing-image-wrapper {
            height: 280px;
        }

        .category-item {
            padding: 0.875rem 1.25rem;
        }

        .category-item i {
            font-size: 1.35rem;
        }

        .category-name {
            font-size: 0.8rem;
        }
    }

    @media (max-width: 480px) {
        .listing-image-wrapper {
            height: 240px;
        }

        .listing-content {
            padding: 1.25rem;
        }

        .pagination-wrapper {
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .pagination-btn {
            padding: 0.65rem 1rem;
            font-size: 0.85rem;
        }
    }
</style>

<div class="homepage-container">
    <!-- Premium Category Filters -->
    <div class="categories-wrapper">
        <div class="categories-scroll">
            <a href="/listings?category=all" class="category-item <%= selectedCategory === 'all' || !selectedCategory ? 'active' : '' %>">
                <i class="fa-solid fa-fire"></i>
                <span class="category-name">All</span>
            </a>
            <a href="/listings?category=Trending" class="category-item <%= selectedCategory === 'Trending' ? 'active' : '' %>">
                <i class="fa-solid fa-chart-line"></i>
                <span class="category-name">Trending</span>
            </a>
            <a href="/listings?category=Rooms" class="category-item <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
                <i class="fa-solid fa-bed"></i>
                <span class="category-name">Rooms</span>
            </a>
            <a href="/listings?category=Iconic Cities" class="category-item <%= selectedCategory === 'Iconic Cities' ? 'active' : '' %>">
                <i class="fa-solid fa-city"></i>
                <span class="category-name">Iconic Cities</span>
            </a>
            <a href="/listings?category=Mountains" class="category-item <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
                <i class="fa-solid fa-mountain"></i>
                <span class="category-name">Mountains</span>
            </a>
            <a href="/listings?category=Castles" class="category-item <%= selectedCategory === 'Castles' ? 'active' : '' %>">
                <i class="fa-brands fa-fort-awesome"></i>
                <span class="category-name">Castles</span>
            </a>
            <a href="/listings?category=Amazing Pools" class="category-item <%= selectedCategory === 'Amazing Pools' ? 'active' : '' %>">
                <i class="fa-solid fa-water-ladder"></i>
                <span class="category-name">Amazing Pools</span>
            </a>
            <a href="/listings?category=Camping" class="category-item <%= selectedCategory === 'Camping' ? 'active' : '' %>">
                <i class="fa-solid fa-campground"></i>
                <span class="category-name">Camping</span>
            </a>
            <a href="/listings?category=Farms" class="category-item <%= selectedCategory === 'Farms' ? 'active' : '' %>">
                <i class="fa-solid fa-tractor"></i>
                <span class="category-name">Farms</span>
            </a>
            <a href="/listings?category=Arctic" class="category-item <%= selectedCategory === 'Arctic' ? 'active' : '' %>">
                <i class="fa-regular fa-snowflake"></i>
                <span class="category-name">Arctic</span>
            </a>
            <a href="/listings?category=Beach" class="category-item <%= selectedCategory === 'Beach' ? 'active' : '' %>">
                <i class="fa-solid fa-umbrella-beach"></i>
                <span class="category-name">Beach</span>
            </a>
            <a href="/listings?category=Lakefront" class="category-item <%= selectedCategory === 'Lakefront' ? 'active' : '' %>">
                <i class="fa-solid fa-ship"></i>
                <span class="category-name">Lakefront</span>
            </a>
            <a href="/listings?category=Countryside" class="category-item <%= selectedCategory === 'Countryside' ? 'active' : '' %>">
                <i class="fa-solid fa-tree"></i>
                <span class="category-name">Countryside</span>
            </a>
        </div>
    </div>

    <% if (allListings.length === 0) { %>
        <!-- No Listings (keeping existing premium design) -->
        <style>
            .no-listings-container {
                min-height: 60vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 3rem 1rem;
            }

            .no-listings-card {
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: blur(20px);
                border: 1px solid rgba(0, 0, 0, 0.08);
                border-radius: 24px;
                padding: 3rem 2rem;
                max-width: 600px;
                width: 100%;
                text-align: center;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            }

            .no-listings-icon {
                width: 100px;
                height: 100px;
                background: rgba(0, 0, 0, 0.05);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 2rem;
            }

            .no-listings-icon i {
                font-size: 3rem;
                color: #000000;
            }

            .no-listings-title {
                font-size: 2rem;
                font-weight: 800;
                color: #000000;
                margin-bottom: 1rem;
                letter-spacing: -1px;
            }

            .no-listings-text {
                color: rgba(0, 0, 0, 0.6);
                font-size: 1.05rem;
                margin-bottom: 2rem;
            }

            .btn-back-home {
                background: #000000;
                color: white;
                border: none;
                padding: 1rem 2.5rem;
                border-radius: 16px;
                font-size: 1rem;
                font-weight: 600;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 0.75rem;
                transition: all 0.3s ease;
            }

            .btn-back-home:hover {
                background: #1a1a1a;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
            }
        </style>

        <div class="no-listings-container">
            <div class="no-listings-card">
                <div class="no-listings-icon">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                <h2 class="no-listings-title">No Listings Found</h2>
                <p class="no-listings-text">
                    <% if (selectedCategory && selectedCategory !== 'all') { %>
                        No properties found in <%= selectedCategory %> category.
                    <% } else { %>
                        No properties available at the moment.
                    <% } %>
                </p>
                <a href="/listings" class="btn-back-home">
                    <i class="fa-solid fa-arrow-left"></i>
                    View All Listings
                </a>
            </div>
        </div>
    <% } else { %>
        <!-- Premium Listings Grid - 3 Columns -->
        <div class="listings-grid">
            <% for (let listing of allListings) { %>
                <a href="/listings/<%= listing._id %>" style="text-decoration: none; color: inherit;">
                    <div class="listing-card">
                        <div class="listing-image-wrapper">
                            <% if (listing.placementLevel && (listing.placementLevel === 'Premium' || listing.placementLevel === 'Luxury')) { %>
                                <span class="placement-badge badge-<%= listing.placementLevel.toLowerCase() %>">
                                    <%= listing.placementLevel %>
                                </span>
                            <% } %>
                            <button class="favorite-btn" onclick="event.preventDefault(); event.stopPropagation();" aria-label="Add to favorites">
                                <i class="fa-regular fa-heart"></i>
                            </button>
                            <img 
                                src="<%= listing.image.url %>" 
                                alt="<%= listing.title %>" 
                                class="listing-image"
                                loading="lazy"
                            >
                        </div>
                        <div class="listing-content">
                            <h3 class="listing-title"><%= listing.title %></h3>
                            <div class="listing-location">
                                <i class="fa-solid fa-location-dot"></i>
                                <span><%= listing.location %>, <%= listing.country %></span>
                            </div>
                            <div class="listing-price">
                                <span class="price-amount">₹<%= listing.price.toLocaleString("en-IN") %></span>
                                <span class="price-period">/ night</span>
                            </div>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>

        <!-- Premium Pagination -->
        <% if (totalPages > 1) { %>
            <div class="pagination-wrapper">
                <% if (currentPage > 1) { %>
                    <a href="/listings?page=<%= currentPage - 1 %>&limit=<%= limit %><%= selectedCategory && selectedCategory !== 'all' ? '&category=' + selectedCategory : '' %>" class="pagination-btn prev">
                        <i class="fa-solid fa-chevron-left"></i> Previous
                    </a>
                <% } %>

                <% let startPage = Math.max(currentPage - 2, 1); %>
                <% let endPage = Math.min(currentPage + 2, totalPages); %>

                <% if (startPage > 1) { %>
                    <a href="/listings?page=1&limit=<%= limit %><%= selectedCategory && selectedCategory !== 'all' ? '&category=' + selectedCategory : '' %>" class="pagination-btn">1</a>
                    <% if (startPage > 2) { %>
                        <span class="pagination-dots">...</span>
                    <% } %>
                <% } %>

                <% for (let page = startPage; page <= endPage; page++) { %>
                    <a href="/listings?page=<%= page %>&limit=<%= limit %><%= selectedCategory && selectedCategory !== 'all' ? '&category=' + selectedCategory : '' %>" class="pagination-btn <%= currentPage === page ? 'active' : '' %>">
                        <%= page %>
                    </a>
                <% } %>

                <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                        <span class="pagination-dots">...</span>
                    <% } %>
                    <a href="/listings?page=<%= totalPages %>&limit=<%= limit %><%= selectedCategory && selectedCategory !== 'all' ? '&category=' + selectedCategory : '' %>" class="pagination-btn"><%= totalPages %></a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="/listings?page=<%= currentPage + 1 %>&limit=<%= limit %><%= selectedCategory && selectedCategory !== 'all' ? '&category=' + selectedCategory : '' %>" class="pagination-btn next">
                        Next <i class="fa-solid fa-chevron-right"></i>
                    </a>
                <% } %>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    // Smooth scroll for categories
    const categoriesScroll = document.querySelector('.categories-scroll');
    if (categoriesScroll) {
        // Auto-scroll to active category
        const activeCategory = categoriesScroll.querySelector('.category-item.active');
        if (activeCategory) {
            activeCategory.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
    }

    // Favorite button interaction
    document.querySelectorAll('.favorite-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const icon = this.querySelector('i');
            if (icon.classList.contains('fa-regular')) {
                icon.classList.remove('fa-regular');
                icon.classList.add('fa-solid');
            } else {
                icon.classList.remove('fa-solid');
                icon.classList.add('fa-regular');
            }
        });
    });
</script>

