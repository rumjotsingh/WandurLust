<% layout("/layouts/boilerplate") %>

<style>
    /* Clean Airbnb Homepage */
    .homepage-container {
        max-width: 1760px;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
    }

    /* Hero Section - Airbnb Style */
    .hero-section {
        margin-bottom: 3rem;
        animation: fadeInDown 0.6s ease;
    }

    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero-title {
        font-size: 2rem;
        font-weight: 700;
        color: #222222;
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
    }

    .hero-subtitle {
        font-size: 1rem;
        color: #6a6a6a;
        font-weight: 400;
    }

    /* Airbnb Listings Grid - 4 Columns */
    .listings-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2.5rem 1.5rem;
        animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Airbnb Listing Card */
    .listing-card {
        background: transparent;
        border-radius: 0;
        overflow: visible;
        transition: all 0.2s ease;
        cursor: pointer;
        position: relative;
    }

    .listing-card:hover {
        transform: translateY(-2px);
    }

    .listing-image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        border-radius: 12px;
        margin-bottom: 0.75rem;
        background: #f7f7f7;
    }

    .listing-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .listing-card:hover .listing-image {
        transform: scale(1.05);
    }

    .favorite-btn {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.9);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        z-index: 10;
        backdrop-filter: blur(10px);
    }

    .favorite-btn:hover {
        background: white;
        transform: scale(1.1);
    }

    .favorite-btn i {
        font-size: 0.875rem;
        color: #222222;
    }

    .listing-content {
        padding: 0;
    }

    .listing-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 0.25rem;
    }

    .listing-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #222222;
        letter-spacing: -0.18px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.2;
        flex: 1;
    }

    .listing-rating {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.875rem;
        color: #222222;
        font-weight: 500;
        white-space: nowrap;
        margin-left: 0.5rem;
    }

    .listing-rating i {
        font-size: 0.75rem;
    }

    .listing-location {
        color: #6a6a6a;
        font-size: 0.9375rem;
        font-weight: 400;
        margin-bottom: 0.25rem;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.25;
    }

    .listing-details {
        color: #6a6a6a;
        font-size: 0.9375rem;
        font-weight: 400;
        margin-bottom: 0.5rem;
    }

    .listing-price {
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
        margin-top: 0.5rem;
    }

    .price-amount {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #222222;
        letter-spacing: 0;
    }

    .price-period {
        font-size: 0.9375rem;
        font-weight: 400;
        color: #222222;
    }

    /* Pagination - Airbnb Style */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid #ebebeb;
    }

    .pagination-btn {
        background: transparent;
        color: #222222;
        border: 1px solid #dddddd;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 44px;
        justify-content: center;
    }

    .pagination-btn:hover {
        background: #f7f7f7;
        border-color: #222222;
        color: #222222;
    }

    .pagination-btn.active {
        background: #222222;
        color: #ffffff;
        border-color: #222222;
    }

    .pagination-btn.prev,
    .pagination-btn.next {
        background: #ffffff;
        color: #222222;
        border-color: #222222;
    }

    .pagination-btn.prev:hover,
    .pagination-btn.next:hover {
        background: #222222;
        color: #ffffff;
    }

    .pagination-dots {
        color: #6a6a6a;
        padding: 0 0.5rem;
        font-weight: 600;
    }

    /* Empty State */
    .no-listings-container {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .no-listings-card {
        background: #ffffff;
        border: 1px solid #ebebeb;
        border-radius: 16px;
        padding: 3rem 2rem;
        max-width: 500px;
        width: 100%;
        text-align: center;
    }

    .no-listings-icon {
        width: 80px;
        height: 80px;
        background: #f7f7f7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }

    .no-listings-icon i {
        font-size: 2rem;
        color: #6a6a6a;
    }

    .no-listings-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.75rem;
    }

    .no-listings-text {
        color: #6a6a6a;
        font-size: 1rem;
        margin-bottom: 1.5rem;
        line-height: 1.5;
    }

    .btn-back-home {
        background: #222222;
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
    }

    .btn-back-home:hover {
        background: #000000;
        color: white;
        transform: scale(0.96);
    }

    /* Responsive - Airbnb Breakpoints */
    @media (max-width: 1440px) {
        .listings-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @media (max-width: 1128px) {
        .listings-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem 1.5rem;
        }
    }

    @media (max-width: 950px) {
        .listings-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .hero-title {
            font-size: 1.75rem;
        }
    }

    @media (max-width: 768px) {
        .homepage-container {
            padding: 1.5rem 1.5rem 3rem;
        }

        .listings-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem 1rem;
        }

        .hero-title {
            font-size: 1.5rem;
        }

        .hero-subtitle {
            font-size: 0.9375rem;
        }
    }

    @media (max-width: 550px) {
        .listings-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .listing-image-wrapper {
            aspect-ratio: 4 / 3;
        }
    }

    @media (max-width: 480px) {
        .homepage-container {
            padding: 1rem 1rem 2rem;
        }
    }
</style>

<div class="homepage-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <h1 class="hero-title">
            <% if (totalCount > 0) { %>
                <%= totalCount %> <%= totalCount === 1 ? 'stay' : 'stays' %> available
            <% } else { %>
                Explore amazing places
            <% } %>
        </h1>
        <p class="hero-subtitle">Discover unique homes and experiences around the world</p>
    </div>

    <% if (allListings.length === 0) { %>
        <!-- No Listings -->
        <div class="no-listings-container">
            <div class="no-listings-card">
                <div class="no-listings-icon">
                    <i class="fa-solid fa-house-circle-xmark"></i>
                </div>
                <h2 class="no-listings-title">No stays found</h2>
                <p class="no-listings-text">
                    Try adjusting your search or filters to find what you're looking for.
                </p>
                <a href="/" class="btn-back-home">
                    <i class="fa-solid fa-arrow-left"></i>
                    Back to home
                </a>
            </div>
        </div>
    <% } else { %>
        <!-- Listings Grid -->
        <div class="listings-grid">
            <% for (let listing of allListings) { %>
                <a href="/listings/<%= listing._id %>" style="text-decoration: none; color: inherit;">
                    <div class="listing-card">
                        <div class="listing-image-wrapper">
                            <button class="favorite-btn" onclick="event.preventDefault(); event.stopPropagation();" aria-label="Add to favorites">
                                <i class="fa-regular fa-heart"></i>
                            </button>
                            <img 
                                src="<%= listing.image.url %>" 
                                alt="<%= listing.title %>" 
                                class="listing-image"
                                loading="lazy"
                            >
                        </div>
                        <div class="listing-content">
                            <div class="listing-header">
                                <h3 class="listing-title"><%= listing.title %></h3>
                                <% if (listing.reviews && listing.reviews.length > 0) { %>
                                    <div class="listing-rating">
                                        <i class="fa-solid fa-star"></i>
                                        <span>4.9</span>
                                    </div>
                                <% } %>
                            </div>
                            <div class="listing-location">
                                <%= listing.location %>, <%= listing.country %>
                            </div>
                            <div class="listing-details">
                                <%= listing.guests || 2 %> guests · <%= listing.bedrooms || 1 %> bedroom
                            </div>
                            <div class="listing-price">
                                <span class="price-amount">₹<%= listing.price.toLocaleString("en-IN") %></span>
                                <span class="price-period">night</span>
                            </div>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="pagination-wrapper">
                <% if (currentPage > 1) { %>
                    <a href="/?page=<%= currentPage - 1 %>&limit=<%= limit %>" class="pagination-btn prev">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                <% } %>

                <% let startPage = Math.max(currentPage - 2, 1); %>
                <% let endPage = Math.min(currentPage + 2, totalPages); %>

                <% if (startPage > 1) { %>
                    <a href="/?page=1&limit=<%= limit %>" class="pagination-btn">1</a>
                    <% if (startPage > 2) { %>
                        <span class="pagination-dots">...</span>
                    <% } %>
                <% } %>

                <% for (let page = startPage; page <= endPage; page++) { %>
                    <a href="/?page=<%= page %>&limit=<%= limit %>" class="pagination-btn <%= currentPage === page ? 'active' : '' %>">
                        <%= page %>
                    </a>
                <% } %>

                <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                        <span class="pagination-dots">...</span>
                    <% } %>
                    <a href="/?page=<%= totalPages %>&limit=<%= limit %>" class="pagination-btn"><%= totalPages %></a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="/?page=<%= currentPage + 1 %>&limit=<%= limit %>" class="pagination-btn next">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                <% } %>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    // Favorite button interaction
    document.querySelectorAll('.favorite-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const icon = this.querySelector('i');
            if (icon.classList.contains('fa-regular')) {
                icon.classList.remove('fa-regular');
                icon.classList.add('fa-solid');
                icon.style.color = '#ff385c';
            } else {
                icon.classList.remove('fa-solid');
                icon.classList.add('fa-regular');
                icon.style.color = '#222222';
            }
        });
    });
</script>
