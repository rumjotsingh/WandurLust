<% layout("/layouts/boilerplate") %>

<style>
    /* Airbnb-Style Search Page */
    .search-container {
        max-width: 1760px;
        margin: 0 auto;
        padding: 2rem;
    }
    
    /* Search Header */
    .search-header {
        background: #ffffff;
        border-bottom: 1px solid #dddddd;
        padding: 2rem 0;
        margin-bottom: 2rem;
        animation: fadeInDown 0.6s ease;
    }

    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .search-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.5rem;
        letter-spacing: -0.44px;
    }
    
    .search-query {
        font-weight: 600;
        color: #222222;
    }
    
    .results-count {
        color: #6a6a6a;
        font-size: 0.875rem;
        font-weight: 500;
        margin-top: 0.5rem;
    }

    .results-count strong {
        color: #222222;
        font-weight: 600;
    }
    
    /* Airbnb Grid */
    .listings-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2.5rem 1.5rem;
        margin-bottom: 3rem;
    }
    
    .listing-card {
        background: transparent;
        border-radius: 0;
        overflow: visible;
        transition: all 0.2s ease;
        cursor: pointer;
        animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .listing-card:hover {
        transform: translateY(-2px);
    }
    
    .card-position {
        position: relative;
        overflow: hidden;
        border-radius: 14px;
        margin-bottom: 0.75rem;
    }

    .listing-card img {
        height: 100%;
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: all 0.3s ease;
        border-radius: 14px;
    }

    .listing-card:hover img {
        transform: scale(1.04);
    }
    
    .card-body {
        padding: 0;
    }

    .card-text {
        color: #6a6a6a;
        font-size: 0.9375rem;
        font-weight: 500;
        line-height: 1.25;
    }

    .card-text strong {
        color: #222222;
        font-weight: 600;
        font-size: 0.9375rem;
        display: block;
        margin-bottom: 0.25rem;
    }

    .listing-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }
    
    .placement-badge {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        padding: 0.375rem 0.75rem;
        border-radius: 4px;
        font-size: 0.6875rem;
        font-weight: 700;
        z-index: 10;
        text-transform: uppercase;
        letter-spacing: 0.32px;
        background: #ffffff;
        color: #222222;
    }
    
    /* No Results - Airbnb Style */
    .no-results {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .no-results-card {
        background: #ffffff;
        border: 1px solid #dddddd;
        border-radius: 14px;
        padding: 2rem;
        max-width: 568px;
        width: 100%;
        text-align: center;
        box-shadow: rgba(0, 0, 0, 0.02) 0 0 0 1px, rgba(0, 0, 0, 0.04) 0 2px 6px 0;
        animation: fadeInUp 0.6s ease;
    }
    
    .no-results-icon {
        width: 80px;
        height: 80px;
        background: #f7f7f7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }
    
    .no-results-icon i {
        font-size: 2.5rem;
        color: #222222;
    }
    
    .no-results-title {
        font-size: 1.375rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.75rem;
        letter-spacing: -0.44px;
    }
    
    .no-results-text {
        color: #6a6a6a;
        font-size: 0.9375rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        line-height: 1.43;
    }
    
    .suggestions-box {
        background: #f7f7f7;
        border: 1px solid #dddddd;
        border-radius: 14px;
        padding: 1.5rem;
        margin: 1.5rem 0;
        text-align: left;
    }
    
    .suggestions-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: #222222;
        margin-bottom: 1rem;
        letter-spacing: 0;
    }
    
    .suggestions-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .suggestion-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        color: #6a6a6a;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .suggestion-item i {
        width: 20px;
        height: 20px;
        background: #222222;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.625rem;
        flex-shrink: 0;
    }
    
    .btn-browse {
        background: #ff385c;
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
        letter-spacing: 0;
    }
    
    .btn-browse:hover {
        background: #e00b41;
        color: white;
        transform: scale(0.96);
    }
    
    /* Responsive */
    @media (max-width: 1440px) {
        .listings-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 1128px) {
        .listings-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem 1.5rem;
        }
    }

    @media (max-width: 950px) {
        .listings-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .search-container {
            padding: 1.5rem;
        }

        .search-header {
            padding: 1.5rem 0;
        }

        .search-title {
            font-size: 1.5rem;
        }
        
        .listings-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem 1rem;
        }

        .no-results-card {
            padding: 1.5rem;
        }

        .no-results-title {
            font-size: 1.25rem;
        }

        .no-results-icon {
            width: 70px;
            height: 70px;
        }

        .no-results-icon i {
            font-size: 2rem;
        }

        .suggestions-box {
            padding: 1.25rem;
        }
    }

    @media (max-width: 550px) {
        .listings-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }
</style>

<div class="search-container">
    <!-- Search Header -->
    <div class="search-header">
        <h1 class="search-title">
            <% if (searchQuery) { %>
                <span class="search-query"><%= totalCount %></span> stays in "<%= searchQuery %>"
            <% } else { %>
                Search Results
            <% } %>
        </h1>
    </div>

    <% if (totalCount > 0) { %>
        <!-- Airbnb Listings Grid -->
        <div class="listings-grid">
            <% for (let listing of allListings) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="listing-card">
                        <div class="card-position">
                            <% if (listing.placementLevel && (listing.placementLevel === 'Premium' || listing.placementLevel === 'Luxury')) { %>
                                <span class="placement-badge">
                                    <%= listing.placementLevel %>
                                </span>
                            <% } %>
                            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" loading="lazy">
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong><%= listing.title %></strong>
                                <span style="display: block; color: #6a6a6a; margin-top: 0.25rem;"><%= listing.location %>, <%= listing.country %></span>
                                <span style="display: block; margin-top: 0.5rem;">
                                    <strong style="color: #222222;">₹<%= listing.price.toLocaleString("en-IN") %></strong> 
                                    <span style="font-weight: 500;">night</span>
                                </span>
                            </p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    <% } else { %>
        <!-- No Results -->
        <div class="no-results">
            <div class="no-results-card">
                <div class="no-results-icon">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                
                <h2 class="no-results-title">No exact matches</h2>
                
                <p class="no-results-text">
                    <% if (searchQuery) { %>
                        Try changing or removing some of your filters or adjusting your search area.
                    <% } else { %>
                        We couldn't find any properties matching your search.
                    <% } %>
                </p>
                
                <div class="suggestions-box">
                    <h3 class="suggestions-title">Search suggestions</h3>
                    <ul class="suggestions-list">
                        <li class="suggestion-item">
                            <i class="fa-solid fa-check"></i>
                            <span>Check your spelling</span>
                        </li>
                        <li class="suggestion-item">
                            <i class="fa-solid fa-check"></i>
                            <span>Try more general keywords</span>
                        </li>
                        <li class="suggestion-item">
                            <i class="fa-solid fa-check"></i>
                            <span>Search for a different location</span>
                        </li>
                    </ul>
                </div>
                
                <a href="/listings" class="btn-browse">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Browse all</span>
                </a>
            </div>
        </div>
    <% } %>
</div>
