<%layout("/layouts/boilerplate")%>

<style>
    .listing-form-container {
        min-height: 80vh;
        padding: 2rem 1rem;
        max-width: 900px;
        margin: 0 auto;
    }
    
    /* Premium Header */
    .form-header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .form-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -1px;
        color: var(--black);
    }
    
    .btn-back {
        background: transparent;
        color: var(--black);
        border: 1px solid rgba(0, 0, 0, 0.15);
        padding: 0.6rem 1.5rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        white-space: nowrap;
    }
    
    .btn-back:hover {
        background: rgba(0, 0, 0, 0.05);
        color: var(--black);
        border-color: var(--black);
    }
    
    /* Premium Form Card */
    .form-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        animation: fadeInUp 0.6s ease 0.1s both;
    }
    
    .form-body {
        padding: 2.5rem;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-weight: 600;
        color: var(--black);
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.9rem;
        letter-spacing: -0.2px;
    }
    
    .form-label i {
        margin-right: 0.5rem;
        color: rgba(0, 0, 0, 0.5);
    }
    
    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--gray-300);
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(0, 0, 0, 0.02);
        width: 100%;
        color: var(--black);
    }
    
    .form-control:focus, .form-select:focus {
        border-color: var(--black);
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
        background: var(--white);
        outline: none;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }
    
    /* Amenities Checkboxes */
    .amenities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 0.75rem;
        margin-top: 0.75rem;
    }
    
    .amenity-check {
        background: rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .amenity-check:hover {
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.15);
    }
    
    .amenity-check input[type="checkbox"] {
        margin-right: 0.75rem;
        width: 18px;
        height: 18px;
        cursor: pointer;
    }
    
    .amenity-check input[type="checkbox"]:checked + label {
        font-weight: 600;
    }
    
    .amenity-check label {
        cursor: pointer;
        margin: 0;
        font-size: 0.9rem;
        color: var(--black);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .amenity-check label i {
        color: rgba(0, 0, 0, 0.5);
    }
    
    /* Property Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
    }
    
    /* Action Buttons */
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }
    
    .btn-cancel {
        flex: 1;
        background: transparent;
        color: var(--black);
        border: 1px solid var(--gray-300);
        border-radius: 12px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    
    .btn-cancel:hover {
        background: var(--gray-100);
        border-color: var(--black);
        color: var(--black);
    }
    
    .btn-submit {
        flex: 2;
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: 12px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        letter-spacing: -0.2px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    
    .btn-submit:hover {
        background: var(--gray-800);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }
    
    /* File Upload */
    input[type="file"] {
        padding: 0.875rem 1rem;
    }
    
    input[type="file"]::file-selector-button {
        background: var(--black);
        color: var(--white);
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        margin-right: 1rem;
        transition: all 0.3s ease;
    }
    
    input[type="file"]::file-selector-button:hover {
        background: var(--gray-800);
    }
    
    @media (max-width: 768px) {
        .form-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
            padding: 2rem 1.5rem;
        }
        
        .form-header h1 {
            font-size: 1.75rem;
        }
        
        .form-body {
            padding: 2rem 1.5rem;
        }
        
        .form-actions {
            flex-direction: column;
        }
        
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .amenities-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="listing-form-container">
    <!-- Header -->
    <div class="form-header">
        <h1>Create New Listing</h1>
        <a href="/listings" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Back
        </a>
    </div>
    
    <!-- Form Card -->
    <div class="form-card">
        <div class="form-body">
            <form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
                <!-- Title -->
                <div class="form-group">
                    <label for="title" class="form-label">
                        <i class="fa-solid fa-heading"></i> Title
                    </label>
                    <input 
                        name="listing[title]" 
                        id="title"
                        placeholder="Enter a catchy title" 
                        type="text" 
                        class="form-control" 
                        required
                    >
                    <div class="invalid-feedback">Please enter a title</div>
                </div>
                
                <!-- Description -->
                <div class="form-group">
                    <label for="description" class="form-label">
                        <i class="fa-solid fa-align-left"></i> Description
                    </label>
                    <textarea 
                        name="listing[description]" 
                        id="description"
                        placeholder="Describe your property" 
                        class="form-control" 
                        required
                    ></textarea>
                    <div class="invalid-feedback">Please enter a description</div>
                </div>

                <!-- Category & Placement Level -->
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="category" class="form-label">
                            <i class="fa-solid fa-tag"></i> Category
                        </label>
                        <select name="listing[category]" id="category" class="form-control form-select" required>
                            <option value="">Select Category</option>
                            <option value="Trending">Trending</option>
                            <option value="Rooms">Rooms</option>
                            <option value="Iconic Cities">Iconic Cities</option>
                            <option value="Mountains">Mountains</option>
                            <option value="Castles">Castles</option>
                            <option value="Amazing Pools">Amazing Pools</option>
                            <option value="Camping">Camping</option>
                            <option value="Farms">Farms</option>
                            <option value="Arctic">Arctic</option>
                            <option value="Beach">Beach</option>
                            <option value="Lakefront">Lakefront</option>
                            <option value="Countryside">Countryside</option>
                        </select>
                        <div class="invalid-feedback">Please select a category</div>
                    </div>

                    <div class="col-md-6 form-group">
                        <label for="placementLevel" class="form-label">
                            <i class="fa-solid fa-star"></i> Placement Level
                        </label>
                        <select name="listing[placementLevel]" id="placementLevel" class="form-control form-select" required>
                            <option value="">Select Level</option>
                            <option value="Basic">Basic</option>
                            <option value="Standard" selected>Standard</option>
                            <option value="Premium">Premium</option>
                            <option value="Luxury">Luxury</option>
                        </select>
                        <div class="invalid-feedback">Please select a placement level</div>
                    </div>
                </div>

                <!-- Image Upload -->
                <div class="form-group">
                    <label for="image" class="form-label">
                        <i class="fa-solid fa-image"></i> Upload Listing Image
                    </label>
                    <input 
                        name="listing[image]" 
                        id="image"
                        type="file" 
                        class="form-control" 
                        required
                    >
                    <div class="invalid-feedback">Please upload an image</div>
                </div>

                <!-- Price & Country -->
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="price" class="form-label">
                            <i class="fa-solid fa-dollar-sign"></i> Price (per night)
                        </label>
                        <input 
                            name="listing[price]" 
                            id="price"
                            placeholder="1200" 
                            type="number" 
                            class="form-control" 
                            required
                        >
                        <div class="invalid-feedback">Please enter a valid price</div>
                    </div>

                    <div class="col-md-6 form-group">
                        <label for="country" class="form-label">
                            <i class="fa-solid fa-globe"></i> Country
                        </label>
                        <input 
                            name="listing[country]" 
                            id="country"
                            placeholder="India" 
                            type="text" 
                            class="form-control" 
                            required
                        >
                        <div class="invalid-feedback">Please enter a country</div>
                    </div>
                </div>

                <!-- Location -->
                <div class="form-group">
                    <label for="location" class="form-label">
                        <i class="fa-solid fa-location-dot"></i> Location
                    </label>
                    <input 
                        name="listing[location]" 
                        id="location"
                        placeholder="Jaipur, Rajasthan" 
                        type="text" 
                        class="form-control" 
                        required
                    >
                    <div class="invalid-feedback">Please enter a location</div>
                </div>

                <!-- Property Stats -->
                <div class="stats-grid">
                    <div class="form-group">
                        <label for="guests" class="form-label">
                            <i class="fa-solid fa-users"></i> Guests
                        </label>
                        <input 
                            name="listing[guests]" 
                            id="guests"
                            type="number" 
                            value="2" 
                            min="1" 
                            class="form-control" 
                            required
                        >
                    </div>
                    <div class="form-group">
                        <label for="bedrooms" class="form-label">
                            <i class="fa-solid fa-bed"></i> Bedrooms
                        </label>
                        <input 
                            name="listing[bedrooms]" 
                            id="bedrooms"
                            type="number" 
                            value="1" 
                            min="1" 
                            class="form-control" 
                            required
                        >
                    </div>
                    <div class="form-group">
                        <label for="beds" class="form-label">
                            <i class="fa-solid fa-hotel"></i> Beds
                        </label>
                        <input 
                            name="listing[beds]" 
                            id="beds"
                            type="number" 
                            value="1" 
                            min="1" 
                            class="form-control" 
                            required
                        >
                    </div>
                    <div class="form-group">
                        <label for="bathrooms" class="form-label">
                            <i class="fa-solid fa-bath"></i> Bathrooms
                        </label>
                        <input 
                            name="listing[bathrooms]" 
                            id="bathrooms"
                            type="number" 
                            value="1" 
                            min="1" 
                            class="form-control" 
                            required
                        >
                    </div>
                </div>

                <!-- Amenities -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-list-check"></i> Amenities
                    </label>
                    <div class="amenities-grid">
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="WiFi" id="wifi">
                            <label for="wifi">
                                <i class="fa-solid fa-wifi"></i> WiFi
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Kitchen" id="kitchen">
                            <label for="kitchen">
                                <i class="fa-solid fa-utensils"></i> Kitchen
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Air Conditioning" id="ac">
                            <label for="ac">
                                <i class="fa-solid fa-snowflake"></i> Air Conditioning
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Parking" id="parking">
                            <label for="parking">
                                <i class="fa-solid fa-car"></i> Parking
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Pool" id="pool">
                            <label for="pool">
                                <i class="fa-solid fa-swimming-pool"></i> Pool
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="TV" id="tv">
                            <label for="tv">
                                <i class="fa-solid fa-tv"></i> TV
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Heating" id="heating">
                            <label for="heating">
                                <i class="fa-solid fa-fire"></i> Heating
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Washer" id="washer">
                            <label for="washer">
                                <i class="fa-solid fa-jug-detergent"></i> Washer
                            </label>
                        </div>
                        <div class="amenity-check">
                            <input type="checkbox" name="listing[amenities][]" value="Pet Friendly" id="pet">
                            <label for="pet">
                                <i class="fa-solid fa-paw"></i> Pet Friendly
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="form-actions">
                    <a href="/listings" class="btn-cancel">
                        <i class="fa-solid fa-xmark"></i> Cancel
                    </a>
                    <button type="submit" class="btn-submit">
                        <i class="fa-solid fa-plus"></i> Create Listing
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

