<%layout("/layouts/boilerplate")%>

<style>
    /* Airbnb-Style Auth Container */
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
    
    .auth-card {
        background: #ffffff;
        border: 1px solid #dddddd;
        border-radius: 14px;
        box-shadow: rgba(0, 0, 0, 0.02) 0 0 0 1px, rgba(0, 0, 0, 0.04) 0 2px 6px 0, rgba(0, 0, 0, 0.1) 0 4px 8px 0;
        overflow: hidden;
        max-width: 568px;
        width: 100%;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .auth-header {
        background: #ffffff;
        color: #222222;
        padding: 2rem 2rem 1.5rem;
        text-align: left;
        border-bottom: 1px solid #dddddd;
    }
    
    .auth-header h1 {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 0;
        letter-spacing: -0.44px;
        color: #222222;
    }
    
    .auth-header p {
        margin: 0.5rem 0 0 0;
        color: #6a6a6a;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .auth-body {
        padding: 1.5rem 2rem 2rem;
    }
    
    /* Demo Banner - Airbnb Style */
    .demo-banner {
        background: #f7f7f7;
        border-radius: 14px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        border: 1px solid #dddddd;
    }

    .demo-icon {
        width: 48px;
        height: 48px;
        background: #222222;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .demo-content {
        flex: 1;
    }

    .demo-content h5 {
        color: #222222;
        margin: 0;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0;
    }

    .demo-content p {
        color: #6a6a6a;
        margin: 0;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .btn-demo {
        background: #222222;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .btn-demo:hover {
        background: #000000;
        transform: scale(0.96);
    }

    .divider {
        text-align: center;
        margin: 1.5rem 0;
        position: relative;
    }

    .divider::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background: #dddddd;
    }

    .divider span {
        background: #ffffff;
        padding: 0 1rem;
        color: #6a6a6a;
        font-size: 0.75rem;
        font-weight: 500;
        position: relative;
        z-index: 1;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.75rem;
        letter-spacing: 0;
    }
    
    .form-control {
        border-radius: 8px;
        border: 1px solid #dddddd;
        padding: 0.6875rem 0.75rem;
        font-size: 1rem;
        font-weight: 500;
        transition: all 0.2s ease;
        background: #ffffff;
        color: #222222;
    }
    
    .form-control:focus {
        border-color: #222222;
        box-shadow: none;
        background: #ffffff;
        outline: none;
    }
    
    .btn-auth {
        width: 100%;
        background: linear-gradient(90deg, #ff385c 0%, #e00b41 50%, #92174d 100%);
        color: #ffffff;
        border: none;
        border-radius: 8px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
        letter-spacing: 0;
    }
    
    .btn-auth:hover {
        transform: scale(0.98);
        color: #ffffff;
    }
    
    .auth-footer {
        text-align: center;
        padding: 1rem 2rem;
        background: #f7f7f7;
        border-top: 1px solid #dddddd;
    }
    
    .auth-footer p {
        margin: 0;
        color: #222222;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .auth-footer a {
        color: #222222;
        font-weight: 600;
        text-decoration: underline;
        transition: opacity 0.2s ease;
    }
    
    .auth-footer a:hover {
        opacity: 0.7;
    }
    
    @media (max-width: 576px) {
        .auth-header h1 {
            font-size: 1.25rem;
        }
        
        .auth-body {
            padding: 1.5rem;
        }
        
        .auth-header {
            padding: 1.5rem;
        }

        .demo-banner {
            flex-direction: column;
            text-align: center;
        }

        .btn-demo {
            width: 100%;
        }
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Log in</h1>
            <p>Welcome back to WandurLust</p>
        </div>
        
        <div class="auth-body">
            <!-- Demo Banner -->
            <div class="demo-banner">
                <div class="demo-icon">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <div class="demo-content">
                    <h5>Try Demo Account</h5>
                    <p>Quick access with demo credentials</p>
                </div>
                <button type="button" class="btn-demo" onclick="fillDemoCredentials()">
                    Demo
                </button>
            </div>

            <div class="divider">
                <span>or</span>
            </div>
            
            <form action="/login" method="post" class="needs-validation" novalidate>
                <div class="form-group">
                    <label for="username" class="form-label">USERNAME</label>
                    <input name="username" id="username" type="text" class="form-control" placeholder="Username" required>
                    <div class="invalid-feedback">Please enter your username.</div>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">PASSWORD</label>
                    <input name="password" id="password" type="password" class="form-control" placeholder="Password" required>
                    <div class="invalid-feedback">Please enter your password.</div>
                </div>
                
                <button class="btn btn-auth">
                    Log in
                </button>
            </form>
        </div>
        
        <div class="auth-footer">
            <p>Don't have an account? <a href="/signup">Sign up</a></p>
        </div>
    </div>
</div>

<script>
    function fillDemoCredentials() {
        document.getElementById('username').value = 'demo';
        document.getElementById('password').value = 'demo123';
        
        const demoBtn = document.querySelector('.btn-demo');
        const originalHTML = demoBtn.innerHTML;
        
        demoBtn.innerHTML = '<i class="fa-solid fa-check"></i> Ready';
        demoBtn.style.background = '#008A05';
        
        setTimeout(() => {
            document.querySelector('form[action="/login"]').submit();
        }, 500);
    }
</script>
