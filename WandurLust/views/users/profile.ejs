<%layout("/layouts/boilerplate")%>

<style>
    .profile-container {
        min-height: 80vh;
        padding: 2rem 1rem;
        max-width: 900px;
        margin: 0 auto;
    }
    
    /* Profile Header Card */
    .profile-header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 24px;
        padding: 3rem;
        margin-bottom: 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        text-align: center;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .profile-avatar-large {
        width: 120px;
        height: 120px;
        background: var(--black);
        color: var(--white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }
    
    .profile-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
        letter-spacing: -1px;
        color: var(--black);
    }
    
    .profile-header p {
        color: var(--gray-600);
        margin: 0;
        font-size: 1rem;
    }
    
    /* Profile Edit Card */
    .profile-edit-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        animation: fadeInUp 0.6s ease 0.1s both;
    }
    
    .card-header-premium {
        background: var(--black);
        color: var(--white);
        padding: 2rem 2.5rem;
    }
    
    .card-header-premium h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.5px;
    }
    
    .card-body-premium {
        padding: 2.5rem;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-weight: 600;
        color: var(--black);
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.9rem;
        letter-spacing: -0.2px;
    }
    
    .form-control {
        border-radius: 12px;
        border: 1px solid var(--gray-300);
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(0, 0, 0, 0.02);
        width: 100%;
    }
    
    .form-control:focus {
        border-color: var(--black);
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
        background: var(--white);
        outline: none;
    }
    
    .form-control:disabled {
        background: var(--gray-100);
        color: var(--gray-500);
        cursor: not-allowed;
    }
    
    .info-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--gray-100);
        padding: 0.5rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        color: var(--gray-600);
        margin-top: 0.5rem;
    }
    
    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }
    
    .btn-save {
        flex: 1;
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: 12px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        letter-spacing: -0.2px;
        cursor: pointer;
    }
    
    .btn-save:hover {
        background: var(--gray-800);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }
    
    .btn-logout {
        background: transparent;
        color: var(--black);
        border: 1px solid var(--gray-300);
        border-radius: 12px;
        padding: 0.875rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }
    
    .btn-logout:hover {
        background: var(--gray-100);
        border-color: var(--black);
        color: var(--black);
    }
    
    @media (max-width: 576px) {
        .profile-header {
            padding: 2rem 1.5rem;
        }
        
        .profile-header h1 {
            font-size: 1.75rem;
        }
        
        .profile-avatar-large {
            width: 100px;
            height: 100px;
            font-size: 2.5rem;
        }
        
        .card-body-premium {
            padding: 2rem 1.5rem;
        }
        
        .card-header-premium {
            padding: 1.5rem;
        }
        
        .btn-group {
            flex-direction: column;
        }
    }
</style>

<div class="profile-container">
    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-avatar-large">
            <%= CurrUser.username.charAt(0).toUpperCase() %>
        </div>
        <h1><%= CurrUser.username %></h1>
        <p><%= CurrUser.email %></p>
    </div>
    
    <!-- Edit Profile Card -->
    <div class="profile-edit-card">
        <div class="card-header-premium">
            <h2>Profile Settings</h2>
        </div>
        
        <div class="card-body-premium">
            <form action="/profile" method="POST" class="needs-validation" novalidate>
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        class="form-control" 
                        value="<%= CurrUser.username %>" 
                        disabled
                    >
                    <div class="info-badge">
                        <i class="fa-solid fa-circle-info"></i>
                        Username cannot be changed
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="email" class="form-label">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="form-control" 
                        value="<%= CurrUser.email %>" 
                        required
                    >
                    <div class="invalid-feedback">Please enter a valid email address.</div>
                </div>
                
                <div class="btn-group">
                    <button type="submit" class="btn-save">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                    <a href="/logout" class="btn-logout">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Log Out
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

