<%layout("/layouts/boilerplate")%>

<style>
    /* Airbnb-Style Auth Container */
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
    
    .auth-card {
        background: #ffffff;
        border: 1px solid #dddddd;
        border-radius: 14px;
        box-shadow: rgba(0, 0, 0, 0.02) 0 0 0 1px, rgba(0, 0, 0, 0.04) 0 2px 6px 0, rgba(0, 0, 0, 0.1) 0 4px 8px 0;
        overflow: hidden;
        max-width: 568px;
        width: 100%;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .auth-header {
        background: #ffffff;
        color: #222222;
        padding: 2rem 2rem 1.5rem;
        text-align: left;
        border-bottom: 1px solid #dddddd;
    }
    
    .auth-header h1 {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 0;
        letter-spacing: -0.44px;
        color: #222222;
    }
    
    .auth-header p {
        margin: 0.5rem 0 0 0;
        color: #6a6a6a;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .auth-body {
        padding: 1.5rem 2rem 2rem;
    }
    
    /* Features Banner - Airbnb Style */
    .features-banner {
        display: flex;
        justify-content: space-around;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #f7f7f7;
        border-radius: 14px;
        border: 1px solid #dddddd;
    }

    .feature-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.375rem;
        color: #222222;
    }

    .feature-item i {
        font-size: 1.25rem;
        color: #222222;
    }

    .feature-item span {
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-weight: 600;
        color: #222222;
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.75rem;
        letter-spacing: 0;
    }
    
    .form-control {
        border-radius: 8px;
        border: 1px solid #dddddd;
        padding: 0.6875rem 0.75rem;
        font-size: 1rem;
        font-weight: 500;
        transition: all 0.2s ease;
        background: #ffffff;
        color: #222222;
    }
    
    .form-control:focus {
        border-color: #222222;
        box-shadow: none;
        background: #ffffff;
        outline: none;
    }

    .form-text {
        display: block;
        margin-top: 0.375rem;
        font-size: 0.75rem;
        color: #6a6a6a;
        font-weight: 500;
    }

    /* Terms Checkbox */
    .terms-checkbox {
        margin: 1.5rem 0;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .terms-checkbox input[type="checkbox"] {
        margin-top: 0.125rem;
        width: 16px;
        height: 16px;
        cursor: pointer;
        accent-color: #222222;
    }

    .terms-checkbox label {
        font-size: 0.75rem;
        color: #6a6a6a;
        font-weight: 500;
        line-height: 1.4;
        cursor: pointer;
    }

    .terms-checkbox a {
        color: #222222;
        text-decoration: underline;
        font-weight: 600;
    }

    .terms-checkbox a:hover {
        opacity: 0.7;
    }
    
    .btn-auth {
        width: 100%;
        background: linear-gradient(90deg, #ff385c 0%, #e00b41 50%, #92174d 100%);
        color: #ffffff;
        border: none;
        border-radius: 8px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
        letter-spacing: 0;
    }
    
    .btn-auth:hover {
        transform: scale(0.98);
        color: #ffffff;
    }
    
    .auth-footer {
        text-align: center;
        padding: 1rem 2rem;
        background: #f7f7f7;
        border-top: 1px solid #dddddd;
    }
    
    .auth-footer p {
        margin: 0;
        color: #222222;
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .auth-footer a {
        color: #222222;
        font-weight: 600;
        text-decoration: underline;
        transition: opacity 0.2s ease;
    }
    
    .auth-footer a:hover {
        opacity: 0.7;
    }

    .social-signup {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #dddddd;
    }

    .btn-demo-link {
        display: block;
        width: 100%;
        text-align: center;
        padding: 0.75rem;
        background: #222222;
        color: #ffffff;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all 0.3s ease;
    }

    .btn-demo-link:hover {
        background: #000000;
        transform: scale(0.98);
        color: #ffffff;
    }
    
    @media (max-width: 576px) {
        .auth-header h1 {
            font-size: 1.25rem;
        }
        
        .auth-body {
            padding: 1.5rem;
        }
        
        .auth-header {
            padding: 1.5rem;
        }

        .features-banner {
            gap: 0.5rem;
            padding: 0.875rem;
        }

        .feature-item i {
            font-size: 1.125rem;
        }

        .feature-item span {
            font-size: 0.6875rem;
        }
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Finish signing up</h1>
            <p>Create your WandurLust account</p>
        </div>
        
        <div class="auth-body">
            <!-- Features Banner -->
            <div class="features-banner">
                <div class="feature-item">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Secure</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-bolt"></i>
                    <span>Fast</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-heart"></i>
                    <span>Free</span>
                </div>
            </div>

            <form action="/signup" method="post" class="needs-validation" novalidate>
                <div class="form-group">
                    <label for="username" class="form-label">USERNAME</label>
                    <input name="username" id="username" type="text" class="form-control" placeholder="Username" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please choose a username.</div>
                </div>
                
                <div class="form-group">
                    <label for="email" class="form-label">EMAIL</label>
                    <input name="email" id="email" type="email" class="form-control" placeholder="Email" required>
                    <div class="invalid-feedback">Please provide a valid email.</div>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">PASSWORD</label>
                    <input name="password" id="password" type="password" class="form-control" placeholder="Password" required minlength="6">
                    <small class="form-text">Minimum 6 characters</small>
                    <div class="invalid-feedback">Password must be at least 6 characters.</div>
                </div>
                
                <div class="terms-checkbox">
                    <input type="checkbox" id="terms" required>
                    <label for="terms">
                        I agree to the <a href="/terms" target="_blank">Terms of Service</a> and <a href="/privacy" target="_blank">Privacy Policy</a>
                    </label>
                    <div class="invalid-feedback">You must agree to the terms.</div>
                </div>
                
                <button class="btn btn-auth">
                    Agree and continue
                </button>
            </form>

            <div class="social-signup">
                <p style="text-align: center; color: #6a6a6a; font-size: 0.75rem; margin-bottom: 0.75rem; font-weight: 500;">
                    Or try our demo account
                </p>
                <a href="/login" class="btn-demo-link">
                    <i class="fa-solid fa-bolt"></i> Try Demo
                </a>
            </div>
        </div>
        
        <div class="auth-footer">
            <p>Already have an account? <a href="/login">Log in</a></p>
        </div>
    </div>
</div>
