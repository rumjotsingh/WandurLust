<%layout("/layouts/boilerplate")%>

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
    
    .auth-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        max-width: 480px;
        width: 100%;
        animation: fadeInUp 0.6s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .auth-header {
        background: var(--black);
        color: var(--white);
        padding: 3rem 2.5rem;
        text-align: center;
    }
    
    .auth-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -1px;
    }
    
    .auth-header p {
        margin: 0.75rem 0 0 0;
        opacity: 0.7;
        font-size: 0.95rem;
    }
    
    .auth-body {
        padding: 2.5rem;
    }
    
    /* Features Banner - Black & White */
    .features-banner {
        display: flex;
        justify-content: space-around;
        gap: 1rem;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: var(--gray-50);
        border-radius: 16px;
        border: 1px solid var(--gray-200);
    }

    .feature-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: var(--black);
    }

    .feature-item i {
        font-size: 1.5rem;
        color: var(--black);
    }

    .feature-item span {
        font-size: 0.85rem;
        font-weight: 600;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        font-weight: 600;
        color: var(--black);
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.9rem;
        letter-spacing: -0.2px;
    }
    
    .form-control {
        border-radius: 12px;
        border: 1px solid var(--gray-300);
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(0, 0, 0, 0.02);
    }
    
    .form-control:focus {
        border-color: var(--black);
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
        background: var(--white);
    }

    .form-text {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.85rem;
        color: var(--gray-500);
    }

    /* Terms Checkbox */
    .terms-checkbox {
        margin: 1.5rem 0;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .terms-checkbox input[type="checkbox"] {
        margin-top: 0.25rem;
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--black);
    }

    .terms-checkbox label {
        font-size: 0.85rem;
        color: var(--gray-600);
        line-height: 1.4;
        cursor: pointer;
    }

    .terms-checkbox a {
        color: var(--black);
        text-decoration: none;
        font-weight: 600;
    }

    .terms-checkbox a:hover {
        opacity: 0.7;
    }
    
    .btn-auth {
        width: 100%;
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: 12px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-top: 1rem;
        letter-spacing: -0.2px;
    }
    
    .btn-auth:hover {
        background: var(--gray-800);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        color: var(--white);
    }
    
    .auth-footer {
        text-align: center;
        padding: 1.5rem 2.5rem;
        background: var(--gray-50);
        border-top: 1px solid var(--gray-200);
    }
    
    .auth-footer p {
        margin: 0;
        color: var(--gray-600);
        font-size: 0.95rem;
    }
    
    .auth-footer a {
        color: var(--black);
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.3s ease;
    }
    
    .auth-footer a:hover {
        opacity: 0.7;
    }

    .social-signup {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-demo-link {
        display: block;
        width: 100%;
        text-align: center;
        padding: 0.75rem;
        background: var(--gray-900);
        color: var(--white);
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-demo-link:hover {
        background: var(--black);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        color: var(--white);
    }
    
    @media (max-width: 576px) {
        .auth-header h1 {
            font-size: 1.75rem;
        }
        
        .auth-body {
            padding: 2rem 1.5rem;
        }
        
        .auth-header {
            padding: 2.5rem 1.5rem;
        }

        .features-banner {
            gap: 0.5rem;
            padding: 1rem;
        }

        .feature-item i {
            font-size: 1.25rem;
        }

        .feature-item span {
            font-size: 0.75rem;
        }
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Join WandurLust</h1>
            <p>Start your journey with us today</p>
        </div>
        
        <div class="auth-body">
            <!-- Features Banner -->
            <div class="features-banner">
                <div class="feature-item">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Secure</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-bolt"></i>
                    <span>Fast</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-heart"></i>
                    <span>Free</span>
                </div>
            </div>

            <form action="/signup" method="post" class="needs-validation" novalidate>
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input name="username" id="username" type="text" class="form-control" placeholder="Choose a username" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please choose a username.</div>
                </div>
                
                <div class="form-group">
                    <label for="email" class="form-label">Email</label>
                    <input name="email" id="email" type="email" class="form-control" placeholder="Enter your email" required>
                    <div class="invalid-feedback">Please provide a valid email.</div>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" id="password" type="password" class="form-control" placeholder="Create a password" required minlength="6">
                    <small class="form-text">Minimum 6 characters</small>
                    <div class="invalid-feedback">Password must be at least 6 characters.</div>
                </div>
                
                <div class="terms-checkbox">
                    <input type="checkbox" id="terms" required>
                    <label for="terms">
                        I agree to the <a href="/terms" target="_blank">Terms of Service</a> and <a href="/privacy" target="_blank">Privacy Policy</a>
                    </label>
                    <div class="invalid-feedback">You must agree to the terms.</div>
                </div>
                
                <button class="btn btn-auth">
                    Create Account
                </button>
            </form>

            <div class="social-signup">
                <p class="text-center text-muted mt-3 mb-2">
                    <small>Or try our demo account</small>
                </p>
                <a href="/login" class="btn-demo-link">
                    <i class="fa-solid fa-bolt"></i> Try Demo Account
                </a>
            </div>
        </div>
        
        <div class="auth-footer">
            <p>Already have an account? <a href="/login">Sign in</a></p>
        </div>
    </div>
</div>
