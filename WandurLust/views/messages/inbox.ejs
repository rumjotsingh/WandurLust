<% layout("/layouts/boilerplate") %>

<div class="container mt-5">
  <h2 class="mb-4"><i class="fas fa-inbox"></i> Messages</h2>

  <% if (conversations.length === 0) { %>
    <div class="text-center py-5">
      <i class="fas fa-envelope-open fa-4x text-muted mb-3"></i>
      <h4>No messages yet</h4>
      <p class="text-muted">When you contact hosts or receive messages, they'll appear here.</p>
      <a href="/listings" class="btn btn-primary">Browse Listings</a>
    </div>
  <% } else { %>
    <div class="list-group">
      <% conversations.forEach(conversation => { %>
        <% const otherUser = conversation._id; %>
        <% const lastMsg = conversation.lastMessage; %>
        <% const unreadCount = conversation.unreadCount; %>
        
        <a href="/messages/conversation/<%= otherUser._id %>" class="list-group-item list-group-item-action <%= unreadCount > 0 ? 'list-group-item-primary' : '' %>">
          <div class="d-flex w-100 justify-content-between align-items-start">
            <div class="flex-grow-1">
              <div class="d-flex align-items-center mb-2">
                <div class="avatar-circle me-3">
                  <i class="fas fa-user"></i>
                </div>
                <div>
                  <h5 class="mb-0">
                    <%= otherUser.username %>
                    <% if (unreadCount > 0) { %>
                      <span class="badge bg-primary rounded-pill"><%= unreadCount %></span>
                    <% } %>
                  </h5>
                  <small class="text-muted"><%= otherUser.email %></small>
                </div>
              </div>
              
              <% if (lastMsg.listing) { %>
                <p class="mb-2 text-muted small">
                  <i class="fas fa-home"></i> About: <%= lastMsg.listing.title %>
                </p>
              <% } %>
              
              <p class="mb-1 <%= unreadCount > 0 ? 'fw-bold' : 'text-muted' %>">
                <%= lastMsg.message.length > 100 ? lastMsg.message.substring(0, 100) + '...' : lastMsg.message %>
              </p>
            </div>
            
            <div class="text-end ms-3">
              <small class="text-muted">
                <%= new Date(lastMsg.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
              </small>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>

<style>
  .avatar-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: #e9ecef;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #6c757d;
  }
  
  .list-group-item {
    transition: background-color 0.2s;
  }
  
  .list-group-item:hover {
    background-color: #f8f9fa;
  }
</style>
