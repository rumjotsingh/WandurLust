<%layout("/layouts/boilerplate")%>

<style>
    .static-page {
        max-width: 900px;
        margin: 3rem auto;
        padding: 0 2rem;
    }
    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 3px solid #fe424d;
    }
    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #222222;
        margin-bottom: 1rem;
    }
    .content-section {
        margin-bottom: 2.5rem;
        line-height: 1.8;
    }
    .content-section h2 {
        color: #fe424d;
        font-size: 1.75rem;
        margin-bottom: 1rem;
    }
    .content-section p {
        color: #555;
        font-size: 1.05rem;
    }
</style>

