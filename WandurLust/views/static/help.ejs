<%layout("/layouts/boilerplate")%>

<style>
    .static-page {
        max-width: 900px;
        margin: 3rem auto;
        padding: 0 2rem;
    }
    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 3px solid #fe424d;
    }
    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #222222;
        margin-bottom: 1rem;
    }
    .faq-item {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        border-left: 4px solid #fe424d;
    }
    .faq-item h3 {
        color: #222222;
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
    }
    .faq-item p {
        color: #555;
        line-height: 1.6;
    }
</style>

<div class="static-page">
    <div class="page-header">
        <h1><i class="fa-solid fa-circle-question"></i> Help Center</h1>
        <p>Find answers to commonly asked questions</p>
    </div>

    <div class="faq-item">
        <h3>How do I create a listing?</h3>
        <p>
            Click on "List Your Home" in the navigation bar. Fill out the form with your property details, 
            upload photos, and set your pricing. Once submitted, your listing will be live!
        </p>
    </div>

    <div class="faq-item">
        <h3>How do I book a property?</h3>
        <p>
            Browse our listings, select a property you like, and click on it to view details. When you're ready, 
            contact the host to arrange your booking.
        </p>
    </div>

    <div class="faq-item">
        <h3>What are the payment methods?</h3>
        <p>
            Payment arrangements are made directly between hosts and guests. We recommend using secure payment 
            methods and keeping records of all transactions.
        </p>
    </div>

    <div class="faq-item">
        <h3>How do I contact support?</h3>
        <p>
            You can reach our support team through the Contact Us page. We typically respond within 24 hours 
            on business days.
        </p>
    </div>
</div>
