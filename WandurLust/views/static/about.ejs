<%layout("/layouts/boilerplate")%>

<style>
    .static-page {
        max-width: 900px;
        margin: 3rem auto;
        padding: 0 2rem;
    }
    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 3px solid #fe424d;
    }
    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #222222;
        margin-bottom: 1rem;
    }
    .page-header p {
        font-size: 1.2rem;
        color: #717171;
    }
    .content-section {
        margin-bottom: 2.5rem;
        line-height: 1.8;
    }
    .content-section h2 {
        color: #fe424d;
        font-size: 1.75rem;
        margin-bottom: 1rem;
    }
    .content-section p {
        color: #555;
        font-size: 1.05rem;
    }
</style>

<div class="static-page">
    <div class="page-header">
        <h1><i class="fa-solid fa-info-circle"></i> About WandurLust</h1>
        <p>Discover unique places to stay around the world</p>
    </div>

    <div class="content-section">
        <h2>Our Story</h2>
        <p>
            WandurLust was founded with a simple mission: to make travel accessible and memorable for everyone. 
            We connect travelers with unique accommodations in destinations around the world, from cozy apartments 
            in bustling cities to serene villas by the beach.
        </p>
    </div>

    <div class="content-section">
        <h2>What We Do</h2>
        <p>
            We provide a platform where property owners can list their spaces and travelers can find their perfect 
            home away from home. Whether you're planning a weekend getaway or a month-long adventure, WandurLust 
            has something for everyone.
        </p>
    </div>

    <div class="content-section">
        <h2>Our Values</h2>
        <p>
            Trust, safety, and community are at the heart of everything we do. We're committed to creating a 
            platform where hosts and guests can connect with confidence, share experiences, and create lasting memories.
        </p>
    </div>
</div>
